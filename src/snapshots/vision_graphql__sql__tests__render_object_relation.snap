---
source: src/sql.rs
expression: sql
---
SELECT json_build_object('posts', (SELECT coalesce(json_agg(row_to_json(r1)), '[]'::json) FROM (SELECT t0."title" AS "title", (SELECT row_to_json(r3) FROM (SELECT t2."name" AS "name" FROM "public"."users" t2 WHERE t2."id" = t0."user_id" LIMIT 1) r3) AS "user" FROM "public"."posts" t0) r1)) AS result
