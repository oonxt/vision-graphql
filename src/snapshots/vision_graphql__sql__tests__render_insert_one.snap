WITH m0_input AS (SELECT * FROM (VALUES (1, $1::text)) AS t(ord, "name")), m0 AS (INSERT INTO "public"."users" ("name") SELECT "name" FROM m0_input ORDER BY ord RETURNING *) SELECT json_build_object('insert_users_one', (SELECT json_build_object('id', m0."id") FROM m0 LIMIT 1)) AS result
