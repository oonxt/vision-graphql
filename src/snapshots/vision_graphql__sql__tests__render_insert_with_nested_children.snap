---
source: src/sql.rs
expression: sql
---
WITH m0_input AS (SELECT * FROM (VALUES (1, $1::text)) AS t(ord, "name")), m0 AS (INSERT INTO "public"."users" ("name") SELECT c."name" FROM m0_input c ORDER BY c.ord RETURNING *), m0_ord AS (SELECT *, ROW_NUMBER() OVER () AS ord FROM m0), m0_posts_input AS (SELECT * FROM (VALUES (1, $2::text)) AS t(parent_ord, "title")), m0_posts AS (INSERT INTO "public"."posts" ("title", "user_id") SELECT c."title", p."id" FROM m0_posts_input c JOIN m0_ord p ON p.ord = c.parent_ord RETURNING *), m0_posts_ord AS (SELECT *, ROW_NUMBER() OVER () AS ord FROM m0_posts) SELECT json_build_object('insert_users', json_build_object('affected_rows', ((SELECT count(*) FROM m0) + (SELECT count(*) FROM m0_posts)), 'returning', (SELECT coalesce(json_agg(json_build_object('id', m0."id", 'posts', (SELECT coalesce(json_agg(row_to_json(r1)), '[]'::json) FROM (SELECT t0."title" AS "title" FROM m0_posts t0 WHERE t0."user_id" = m0."id") r1))), '[]'::json) FROM m0))) AS result
