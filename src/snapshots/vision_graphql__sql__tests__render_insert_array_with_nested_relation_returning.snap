assertion_line: 1908
expression: sql
---
WITH m0 AS (INSERT INTO "public"."users" ("name") VALUES ($1) RETURNING *) SELECT json_build_object('insert_users', json_build_object('affected_rows', (SELECT count(*) FROM m0), 'returning', (SELECT coalesce(json_agg(json_build_object('id', m0."id", 'posts', (SELECT coalesce(json_agg(row_to_json(r1)), '[]'::json) FROM (SELECT t0."title" AS "title" FROM "public"."posts" t0 WHERE t0."user_id" = m0."id") r1))), '[]'::json) FROM m0))) AS result
